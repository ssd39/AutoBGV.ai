# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=autobgv
POSTGRES_PASSWORD=autobgv_secret
POSTGRES_DB=autobgv

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ─── MinIO (local S3-compatible for dev) ──────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret

# ─── AWS S3 (production) ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=autobgv-documents

# ─── Application ──────────────────────────────────────────────────────────────
DEFAULT_CLIENT_ID=client_001
ENVIRONMENT=development

# ─── Service URLs (override for Docker Compose) ───────────────────────────────
WORKFLOW_SERVICE_URL=http://workflow-service:8001
AGENT_SERVICE_URL=http://agent-service:8002
VERIFICATION_SERVICE_URL=http://verification-service:8003

# Public base URL that Twilio can reach (webhooks, TwiML, WebSocket stream).
# In local dev: use an ngrok tunnel → https://xxxx.ngrok.io
# In Docker / production: set to your HTTPS domain
AGENT_SERVICE_BASE_URL=http://localhost:8002

# Redis queue key (shared between workflow-service and agent-service — must match)
SESSION_CREATED_QUEUE=queue:agent:session.created

# ─── Redis URLs (per-service) ─────────────────────────────────────────────────
# Workflow service uses DB 0 (default):
#   REDIS_URL=redis://:redis_secret@localhost:6379/0
#
# Agent service uses DB 1 for session state (default):
#   REDIS_URL=redis://:redis_secret@localhost:6379/1
#
# Agent service MUST also read the queue from the SAME DB as the workflow service (DB 0).
# This is set via QUEUE_REDIS_URL (defaults to DB 0 — do NOT change unless you also
# change the workflow service's REDIS_URL):
#   QUEUE_REDIS_URL=redis://:redis_secret@localhost:6379/0

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=          # Voice call number (E.164, e.g. +15551234)

# WhatsApp Business sender number registered via Twilio Senders API.
# 1. Call POST /api/v1/whatsapp/senders to create & register the sender.
# 2. Verify with POST /api/v1/whatsapp/senders/{sid} (submit OTP).
# 3. Once status = ONLINE, set this to the sender's phone number.
# Format: whatsapp:+14155238886 or just +14155238886
TWILIO_WHATSAPP_NUMBER=

# Twilio Content Template SID for WhatsApp document-request messages.
# REQUIRED since April 1, 2025 for business-initiated WhatsApp messages.
# Steps:
#   1. Go to Twilio Console → Messaging → Content Template Builder
#   2. Create a template, e.g.:
#        "Hello {{1}}, we need your *{{2}}* to complete your {{3}} process.
#         Please reply with a clear photo or PDF of the document."
#   3. Submit for WhatsApp approval and wait for APPROVED status
#   4. Copy the Content SID (HX...) here
# Variable mapping: {{1}}=customer_name, {{2}}=doc_name, {{3}}=workflow_name
TWILIO_WHATSAPP_CONTENT_SID=

# ─── Deepgram Voice Agent ─────────────────────────────────────────────────────
# Get your API key at https://console.deepgram.com
DEEPGRAM_API_KEY=
# Optional overrides (defaults shown):
# DEEPGRAM_AGENT_URL=wss://agent.deepgram.com/v1/agent/converse
# DEEPGRAM_STT_MODEL=nova-3
# DEEPGRAM_LLM_PROVIDER=google          # open_ai | google | anthropic | aws_bedrock | groq
# DEEPGRAM_LLM_MODEL=gemini-2.5-flash   # must match provider
# DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# ─── External Services ────────────────────────────────────────────────────────
OPENAI_API_KEY=
WHATSAPP_API_TOKEN=
